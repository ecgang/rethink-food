// Rethink Command Center — data model
// Design principle: normalized. Costs are line-itemed (no flat `totalCost`).
// A Meal moves through an explicit lifecycle. A Contract (from a Funder) funds a
// Program which produces Meals. This is the "data definitions" foundation the
// Command Center reports against.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// Enums
// ----------------------------------------------------------------------------

enum ProgramType {
  MTM // Medically Tailored Meals (Medicaid 1115 waiver)
  RESTAURANT_RESPONSE // surplus / restaurant-cooked community meals
  EMERGENCY_RELIEF
}

// State of a single meal through its lifecycle. Order is meaningful.
enum MealStatus {
  PLANNED
  PRODUCED
  DELIVERED
  VERIFIED
}

enum CostType {
  FOOD
  LABOR
  TRANSPORT
  OVERHEAD
}

// Social Care Network lead entities for MTM under NY's 1115 waiver, by NYC region.
// (HEALI serves Long Island — Nassau/Suffolk — so it's intentionally excluded here.)
enum ScnPartner {
  PHS // Public Health Solutions / WholeYouNYC — Manhattan, Brooklyn, Queens
  SOMOS // SOMOS Community Care — Bronx
  SIPPS // Staten Island Performing Provider System — Staten Island
}

enum MemberStatus {
  ACTIVE
  WITHDRAWN
}

enum ProducerType {
  KITCHEN
  RESTAURANT
}

enum IntakeStatus {
  PENDING
  APPROVED
  REJECTED
  FULFILLED
}

enum InvoiceStatus {
  DRAFT
  SUBMITTED
  PAID
}

// ----------------------------------------------------------------------------
// Kitchen & field operations (JD: "production planning, ... food safety, quality
// assurance, ... incident tracking"). These back the field PWA's ops surfaces.
// ----------------------------------------------------------------------------

enum IncidentKind {
  FOOD_SAFETY
  QUALITY
  DELIVERY
  EQUIPMENT
  OTHER
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

// A completed checklist. FOOD_SAFETY and QUALITY share the model; the item set
// per kind lives in pure code (lib/safety.ts) so it's testable and versionable.
enum SafetyCheckKind {
  FOOD_SAFETY
  QUALITY
}

// ----------------------------------------------------------------------------
// Geography
// ----------------------------------------------------------------------------

model Market {
  id           String @id @default(cuid())
  borough      String
  neighborhood String
  lat          Float
  lng          Float
  // estimated weekly meal demand for this neighborhood (for the demand map)
  weeklyDemand Int    @default(0)

  kitchens    Kitchen[]
  restaurants RestaurantPartner[]
  cbos        Cbo[]
  members     Member[]
  meals       Meal[]
  incidents   Incident[]

  @@unique([borough, neighborhood])
}

// ----------------------------------------------------------------------------
// Funding
// ----------------------------------------------------------------------------

model Funder {
  id        String     @id @default(cuid())
  name      String     @unique
  kind      String // e.g. "Government", "Healthcare", "Philanthropy"
  contracts Contract[]
}

model Program {
  id   String      @id @default(cuid())
  name String      @unique
  type ProgramType
  // revenue side of unit economics: what Rethink is reimbursed per delivered meal
  reimbursementRateCents Int

  contracts Contract[]
  meals     Meal[]
}

model Contract {
  id              String      @id @default(cuid())
  name            String
  funder          Funder      @relation(fields: [funderId], references: [id])
  funderId        String
  program         Program     @relation(fields: [programId], references: [id])
  programId       String
  scnPartner      ScnPartner? // only set for MTM contracts
  budgetCents     BigInt
  startDate       DateTime
  endDate         DateTime
  // next billing/invoice deadline — drives an "act on today" exception
  billingDeadline DateTime?
  // when an invoice was last generated for this contract; clears the billing
  // exception for the current cycle (set by the generate-invoice action).
  lastInvoicedAt  DateTime?

  meals    Meal[]
  invoices Invoice[]
}

// An invoice generated for a contract's verified meals over a period. Created by
// the "Generate & submit invoice" action on the Command Center — the closing of
// the reimbursement loop the JD calls out (contract performance / revenue).
model Invoice {
  id          String        @id @default(cuid())
  contract    Contract      @relation(fields: [contractId], references: [id])
  contractId  String
  periodStart DateTime
  periodEnd   DateTime
  mealCount   Int
  amountCents BigInt
  status      InvoiceStatus @default(SUBMITTED)
  createdBy   String // operator identity (audit)
  createdAt   DateTime      @default(now())

  @@index([contractId])
}

// ----------------------------------------------------------------------------
// Producers & recipients
// ----------------------------------------------------------------------------

model Kitchen {
  id             String @id @default(cuid())
  name           String
  market         Market @relation(fields: [marketId], references: [id])
  marketId       String
  weeklyCapacity Int // meals/week the kitchen can produce

  meals        Meal[]
  incidents    Incident[]
  safetyChecks SafetyCheck[]
}

model RestaurantPartner {
  id             String  @id @default(cuid())
  name           String
  address        String?
  certified      Boolean @default(false) // "Rethink Certified" partner
  market         Market  @relation(fields: [marketId], references: [id])
  marketId       String
  weeklyCapacity Int
  minorityOwned  Boolean @default(false)

  meals Meal[]
}

// Community-based organization that receives & distributes meals.
model Cbo {
  id           String  @id @default(cuid())
  name         String
  address      String?
  market       Market  @relation(fields: [marketId], references: [id])
  marketId     String
  contactEmail String?

  meals          Meal[]
  intakeRequests IntakeRequest[]
}

// MTM beneficiary (synthetic). Enables delivered-vs-prescribed + retention.
model Member {
  id                     String       @id @default(cuid())
  externalRef            String       @unique // synthetic Medicaid member ref
  market                 Market       @relation(fields: [marketId], references: [id])
  marketId               String
  scnPartner             ScnPartner
  referralDate           DateTime
  enrollmentDate         DateTime?
  status                 MemberStatus @default(ACTIVE)
  withdrawnAt            DateTime?
  prescribedMealsPerWeek Int          @default(7)

  meals Meal[]
}

// ----------------------------------------------------------------------------
// The meal — the atomic unit everything reports on
// ----------------------------------------------------------------------------

model Meal {
  id         String  @id @default(cuid())
  program    Program @relation(fields: [programId], references: [id])
  programId  String
  contract   Contract @relation(fields: [contractId], references: [id])
  contractId String
  market     Market  @relation(fields: [marketId], references: [id])
  marketId   String

  // exactly one producer is set, indicated by producerType
  producerType        ProducerType
  kitchen             Kitchen?           @relation(fields: [kitchenId], references: [id])
  kitchenId           String?
  restaurantPartner   RestaurantPartner? @relation(fields: [restaurantPartnerId], references: [id])
  restaurantPartnerId String?

  cbo      Cbo     @relation(fields: [cboId], references: [id])
  cboId    String
  member   Member? @relation(fields: [memberId], references: [id])
  memberId String? // set for MTM meals

  // provenance: the approved intake request this meal was scheduled from (Cluster C)
  intakeRequest   IntakeRequest? @relation(fields: [intakeRequestId], references: [id])
  intakeRequestId String?

  // lifecycle: a timestamp per transition, plus a denormalized current status
  status      MealStatus @default(PLANNED)
  mealDate    DateTime // the day this meal is for
  plannedAt   DateTime
  producedAt  DateTime?
  deliveredAt DateTime?
  verifiedAt  DateTime?

  // field-ops audit trail: who advanced each transition (operator identity) and
  // the delivery proof photo captured in the field (Vercel Blob URL).
  producedBy       String?
  deliveredBy      String?
  verifiedBy       String?
  deliveryPhotoUrl String?

  costLineItems MealCostLineItem[]
  incidents     Incident[]

  @@index([status])
  @@index([programId])
  @@index([mealDate])
  @@index([intakeRequestId])
}

model MealCostLineItem {
  id          String   @id @default(cuid())
  meal        Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)
  mealId      String
  type        CostType
  amountCents Int

  @@index([mealId])
}

// ----------------------------------------------------------------------------
// AI intake (human-in-the-loop) — the audit trail
// ----------------------------------------------------------------------------

model IntakeRequest {
  id              String       @id @default(cuid())
  // PII: rawInput + extractedFields hold partner-submitted text (names, locations,
  // dietary/medical constraints). Encrypted at rest by Neon. Demo retains all rows;
  // production needs a retention window + the operator deletion path (deleteIntakeRequest).
  rawInput        String // the pasted email / message
  extractedFields Json // structured output from the LLM (may contain PII)
  confidenceFlags Json // per-field confidence / warnings
  modelUsed       String?
  status          IntakeStatus @default(PENDING)
  approvedBy      String? // operator identity (audit)
  approvedAt      DateTime?
  // closed loop: scheduled into PLANNED meals (Cluster C)
  fulfilledBy     String?
  fulfilledAt     DateTime?
  // link to the CBO once resolved (after approval)
  cbo       Cbo?     @relation(fields: [cboId], references: [id])
  cboId     String?
  // meals scheduled from this request (provenance / traceability)
  meals     Meal[]
  createdAt DateTime @default(now())

  @@index([status])
}

// ----------------------------------------------------------------------------
// Reporting — snapshots produced by the weekly cron (automated recurring report)
// ----------------------------------------------------------------------------

enum ReportKind {
  FUNDER_IMPACT
  BOARD_SUMMARY
}

model ReportSnapshot {
  id          String     @id @default(cuid())
  kind        ReportKind
  title       String
  periodStart DateTime
  periodEnd   DateTime
  payload     Json // the computed report (totals + per-funder lines) at generation time
  generatedBy String // "weekly-cron" or an operator identity
  createdAt   DateTime   @default(now())

  @@index([kind, createdAt])
}

// ----------------------------------------------------------------------------
// "Ask the Operating Layer" — auditable log of natural-language queries (④).
// Answers are grounded in retrieval tools over the models above; `citations`
// holds the record ids/labels surfaced as sources. askedBy gives the audit
// trail (getAuditLog unions this in, the same column pattern as IntakeRequest).
// ----------------------------------------------------------------------------

model AskLog {
  id        String   @id @default(cuid())
  question  String
  answer    String
  citations Json // [{ type, id, label }] surfaced as sources for the answer
  modelUsed String
  askedBy   String // operator identity (audit)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ----------------------------------------------------------------------------
// Draft-and-approve comms agent (⑤). AI drafts a follow-up; a human reviews and
// approves or discards it. NOTHING is ever auto-sent — there is no transport.
// The DRAFT → APPROVED/DISCARDED queue is the "human-reviewed agent" the JD asks
// for; reviewedBy/reviewedAt feed the audit trail (getAuditLog unions this in).
// ----------------------------------------------------------------------------

enum DraftCommKind {
  INTAKE_CLARIFICATION // ask a CBO for fields missing from a pending intake
  DELIVERY_NUDGE // chase a produced-but-undelivered / unverified meal
  RECONCILIATION_FLAG // billing-due / budget-overage note for a contract
  REPORT_NARRATIVE // board/funder summary prose (the folded-in ② narrator)
  INCIDENT_NOTICE // notify a partner of an incident affecting their meals
}

enum DraftCommStatus {
  DRAFT
  APPROVED
  DISCARDED
}

model DraftComm {
  id                String          @id @default(cuid())
  kind              DraftCommKind
  relatedEntityType String // "intake" | "meal" | "contract" | "report"
  relatedEntityId   String
  subject           String
  body              String
  status            DraftCommStatus @default(DRAFT)
  modelUsed         String
  generatedAt       DateTime        @default(now())
  reviewedBy        String? // operator identity once approved/discarded (audit)
  reviewedAt        DateTime?

  @@index([status, generatedAt])
}

// ----------------------------------------------------------------------------
// Incident tracking — a problem logged from the kitchen or field (food-safety
// breach, quality defect, delivery failure, equipment fault). Open HIGH/CRITICAL
// incidents surface as "act on today" exceptions (lib/exceptions.ts) and can spawn
// a draft partner notice (DraftComm INCIDENT_NOTICE). reportedBy/resolvedBy audit.
// ----------------------------------------------------------------------------

model Incident {
  id          String           @id @default(cuid())
  kind        IncidentKind
  severity    IncidentSeverity
  status      IncidentStatus   @default(OPEN)
  title       String
  description String

  // optional context — where/what the incident relates to
  kitchen   Kitchen? @relation(fields: [kitchenId], references: [id])
  kitchenId String?
  market    Market?  @relation(fields: [marketId], references: [id])
  marketId  String?
  meal      Meal?    @relation(fields: [mealId], references: [id])
  mealId    String?

  photoUrl       String? // optional proof photo (Vercel Blob)
  reportedBy     String // operator identity (audit)
  reportedAt     DateTime @default(now())
  resolvedBy     String?
  resolvedAt     DateTime?
  resolutionNote String?

  @@index([status, severity])
  @@index([reportedAt])
}

// ----------------------------------------------------------------------------
// Food-safety / QA checklist result. The item set per kind is defined in pure
// code (lib/safety.ts); `responses` stores the operator's answers and `passed` is
// the computed verdict. A recent failed check surfaces as an exception.
// ----------------------------------------------------------------------------

model SafetyCheck {
  id           String          @id @default(cuid())
  kind         SafetyCheckKind
  kitchen      Kitchen?        @relation(fields: [kitchenId], references: [id])
  kitchenId    String?
  mealDate     DateTime? // the production day this check covers
  responses    Json // [{ itemId, ok, note? }]
  passed       Boolean // computed from responses via evaluateCheck()
  temperatureF Float? // optional cold-holding / pack temperature log
  checkedBy    String // operator identity (audit)
  checkedAt    DateTime        @default(now())

  @@index([kind, checkedAt])
  // getActOnTodayAgg filters recent failed checks: (passed, checkedAt)
  @@index([passed, checkedAt])
}
